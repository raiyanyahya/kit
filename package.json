{
  "name": "kit",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "main": "src/main.js",
  "scripts": {
    "build": "esbuild src/renderer.js --bundle --format=esm --platform=browser --outfile=src/renderer.bundle.js --sourcemap",
    "build:prod": "esbuild src/renderer.js --bundle --format=esm --platform=browser --outfile=src/renderer.bundle.js --minify --tree-shaking=true",
    "dev": "npm run build && electron .",
    "start": "electron .",
    "postinstall": "electron-builder install-app-deps",
    "dist:mac": "npm run build:prod && electron-builder --mac --publish never",
    "test": "node --experimental-vm-modules node_modules/.bin/jest"
  },
  "build": {
    "appId": "com.kit.workspace",
    "productName": "Kit",
    "icon": "icons/kiticon-512.png",
    "asar": true,
    "files": [
      "src/**/*",
      "!src/renderer.js",
      "!src/renderer.bundle.js.map",
      "icons/**/*",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.developertools",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ]
    },
    "linux": {
      "category": "Development",
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "dmg": {
      "title": "${productName} ${version}",
      "icon": "icons/kiticon-100.png",
      "background": null,
      "window": {
        "width": 540,
        "height": 380
      }
    },
    "compression": "maximum"
  },
  "devDependencies": {
    "electron": "^40.0.0",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.28.0",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0"
  },
  "dependencies": {
    "@codemirror/commands": "6.10.3",
    "@codemirror/lang-cpp": "6.0.3",
    "@codemirror/lang-css": "6.3.1",
    "@codemirror/lang-html": "6.4.11",
    "@codemirror/lang-java": "6.0.2",
    "@codemirror/lang-javascript": "6.2.5",
    "@codemirror/lang-json": "6.0.2",
    "@codemirror/lang-markdown": "6.5.0",
    "@codemirror/lang-php": "6.0.2",
    "@codemirror/lang-python": "6.2.1",
    "@codemirror/lang-rust": "6.0.2",
    "@codemirror/lang-sql": "6.10.0",
    "@codemirror/lang-xml": "6.1.0",
    "@codemirror/lang-yaml": "6.1.3",
    "@codemirror/language": "6.12.3",
    "@codemirror/legacy-modes": "6.5.2",
    "@codemirror/search": "6.7.0",
    "@codemirror/state": "6.6.0",
    "@codemirror/theme-one-dark": "6.1.3",
    "@codemirror/view": "6.41.1",
    "imapflow": "^1.2.10",
    "mailparser": "^3.9.3",
    "node-fetch": "^3.3.2",
    "node-pty": "^1.0.0",
    "nodemailer": "^8.0.7",
    "openai": "^6.35.0"
  }
}
